# client/.gitignore - Node + Vite + TypeScript

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Dependency directories
node_modules/

# Production
dist/

# Local env files
.env
.env.local
.env.*.local

# Editor directories and files
.vscode/
!.vscode/extensions.json
.idea/

# OS files
.DS_Store

# TypeScript
*.tsbuildinfo

# Vite
.vite/

# Optional npm cache
.npm

# Other
*.pem

config.ts
