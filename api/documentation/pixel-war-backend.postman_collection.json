{
  "info": {
    "_postman_id": "5177ca51-a007-44ac-a428-f5ab2efcc5d1",
    "name": "Pixel War Backend - Auto Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Smoke tests backend: health -> createGrid -> getAllFrames -> getFrame"
  },
  "item": [
    {
      "name": "1 - Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Health status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('Health payload has status ok', function () {",
              "  pm.expect(body.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2 - Create Grid",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"width\": 4,\n  \"height\": 3,\n  \"name\": \"postman-grid\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/createGrid",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "createGrid"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create grid status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('Create grid response has grid + frames', function () {",
              "  pm.expect(body).to.have.property('grid');",
              "  pm.expect(body).to.have.property('frames');",
              "  pm.expect(body.frames).to.be.an('array');",
              "});",
              "",
              "pm.test('Grid dimensions are correct', function () {",
              "  pm.expect(body.grid.width).to.eql(4);",
              "  pm.expect(body.grid.height).to.eql(3);",
              "});",
              "",
              "pm.test('All created frames are white', function () {",
              "  const hasOnlyWhite = body.frames.every(function (f) { return f.color === '#FFFFFF'; });",
              "  pm.expect(hasOnlyWhite).to.eql(true);",
              "});",
              "",
              "pm.collectionVariables.set('gridId', String(body.grid.id));",
              "pm.environment.set('gridId', String(body.grid.id));",
              "pm.collectionVariables.set('frameX', '0');",
              "pm.collectionVariables.set('frameY', '0');",
              "pm.environment.set('frameX', '0');",
              "pm.environment.set('frameY', '0');"
            ]
          }
        }
      ]
    },
    {
      "name": "3 - Get All Frames (created grid)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/getAllFrames/{{gridId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "getAllFrames",
            "{{gridId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Get all frames status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('Response includes grid and frames', function () {",
              "  pm.expect(body).to.have.property('grid');",
              "  pm.expect(body).to.have.property('frames');",
              "  pm.expect(body.frames).to.be.an('array');",
              "});",
              "",
              "pm.test('Grid id matches created grid', function () {",
              "  pm.expect(String(body.grid.id)).to.eql(String(pm.collectionVariables.get('gridId')));",
              "});",
              "",
              "pm.test('Frame count matches width*height', function () {",
              "  pm.expect(body.frames.length).to.eql(body.grid.width * body.grid.height);",
              "});",
              "",
              "const frame00 = body.frames.find(function (f) { return f.x === 0 && f.y === 0; });",
              "pm.test('Frame (0,0) exists and is white', function () {",
              "  pm.expect(frame00).to.not.eql(undefined);",
              "  pm.expect(frame00.color).to.eql('#FFFFFF');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4 - Get Frame (0,0)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/getFrame/{{gridId}}/{{frameX}}/{{frameY}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "getFrame",
            "{{gridId}}",
            "{{frameX}}",
            "{{frameY}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Get frame status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('Returned frame has expected coordinates', function () {",
              "  pm.expect(body.x).to.eql(Number(pm.collectionVariables.get('frameX')));",
              "  pm.expect(body.y).to.eql(Number(pm.collectionVariables.get('frameY')));",
              "});",
              "",
              "pm.test('Returned frame is white by default', function () {",
              "  pm.expect(body.color).to.eql('#FFFFFF');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) {",
          "  pm.collectionVariables.set('baseUrl', 'http://localhost:8000');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "gridId",
      "value": ""
    },
    {
      "key": "frameX",
      "value": "0"
    },
    {
      "key": "frameY",
      "value": "0"
    }
  ]
}

