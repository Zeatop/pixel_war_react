# Root .gitignore - common ignores for node, editors, envs

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
build/

# Local env files
.env
.env.local
.env.*.local

# Logs
logs/
*.log

# OS
.DS_Store

# Editors/IDE
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Docker
docker-compose.override.yml

# Other
.vite
*.tgz

